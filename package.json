{
  "name": "devextreme-documentation",
  "description": "DevExtreme documentation",
  "author": "Developer Express Inc.",
  "version": "26.2.0",
  "license": "UNLICENSED",
  "engines": {
    "node": "^24.16.0"
  },
  "repository": {
    "type": "git",
